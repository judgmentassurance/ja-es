{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://judgmentassurance.com/schema/ja-es/v0.6/linked-event.schema.json",
  "title": "Judgment Assurance Linked Event Record (JA-ES) v0.6",
  "description": "Post-decision information about an existing Judgment Record. Judgment Records are immutable once written; anything learned afterwards \u2014 a realized outcome, a correction, a probe evaluation \u2014 is carried here as a separate, separately hashed record that references the original by id and hash. This preserves the append-only property that the tamper-evidence claim depends on. Judgment Assurance (Kavalir, 2026). CC BY 4.0.",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "references_record_id",
    "references_record_hash",
    "created_at",
    "created_by",
    "integrity"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "JA-ES-LE-0.6"
    },
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "outcome_feedback",
        "amendment",
        "probe_evaluation"
      ],
      "description": "outcome_feedback = realized result observed later. amendment = correction to an earlier record; the original is never edited. probe_evaluation = scoring of a seeded or blind probe against ground truth."
    },
    "references_record_id": {
      "type": "string",
      "minLength": 1
    },
    "references_record_hash": {
      "type": "string",
      "minLength": 1,
      "description": "Hash of the referenced Judgment Record as written. Binds this event to a specific immutable version and detects substitution of the original."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "outcome_feedback": {
      "type": "object",
      "description": "The only field family supplying ground truth the institution cannot author.",
      "required": [
        "outcome_label",
        "outcome_source",
        "outcome_observed_at"
      ],
      "additionalProperties": false,
      "properties": {
        "outcome_observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "outcome_label": {
          "type": "string",
          "minLength": 1
        },
        "outcome_source": {
          "type": "string",
          "minLength": 1
        },
        "observation_window": {
          "type": "string",
          "description": "e.g. '12 months from origination'."
        },
        "judgment_assessed_correct": {
          "type": "boolean",
          "description": "Retrospective assessment only. Absence is expected and is not a control failure."
        },
        "assessment_basis": {
          "type": "string"
        }
      }
    },
    "amendment": {
      "type": "object",
      "description": "A correction. The original record remains unaltered and retrievable.",
      "required": [
        "reason",
        "fields_corrected"
      ],
      "additionalProperties": false,
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "fields_corrected": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "description": "JSON pointers to the fields superseded, e.g. '/human_action/reasoning/narrative'."
        },
        "corrected_values": {
          "type": "object",
          "description": "The superseding values."
        },
        "supersedes": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "probe_evaluation": {
      "type": "object",
      "description": "Scoring of a probe record against its ground truth. Kept separate so the original decision record carries no post-hoc grade.",
      "required": [
        "probe_id",
        "reviewer_passed"
      ],
      "additionalProperties": false,
      "properties": {
        "probe_id": {
          "type": "string",
          "minLength": 1
        },
        "expected_disposition": {
          "type": "string",
          "enum": [
            "accept",
            "modify",
            "reject"
          ]
        },
        "actual_disposition": {
          "type": "string",
          "enum": [
            "accept",
            "modify",
            "reject",
            "escalate",
            "defer"
          ]
        },
        "reviewer_passed": {
          "type": "boolean"
        },
        "evaluator": {
          "type": "string"
        },
        "evaluator_independent_of_production": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "integrity": {
      "type": "object",
      "required": [
        "record_hash",
        "hash_algorithm",
        "canonicalization"
      ],
      "additionalProperties": false,
      "properties": {
        "record_hash": {
          "type": "string",
          "minLength": 1
        },
        "hash_algorithm": {
          "type": "string",
          "enum": [
            "SHA-256",
            "SHA-384",
            "SHA-512"
          ]
        },
        "canonicalization": {
          "type": "string",
          "const": "RFC8785"
        },
        "signature": {
          "type": "string"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "outcome_feedback"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "required": [
          "outcome_feedback"
        ],
        "not": {
          "anyOf": [
            {
              "required": [
                "amendment"
              ]
            },
            {
              "required": [
                "probe_evaluation"
              ]
            }
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "amendment"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "required": [
          "amendment"
        ],
        "not": {
          "anyOf": [
            {
              "required": [
                "outcome_feedback"
              ]
            },
            {
              "required": [
                "probe_evaluation"
              ]
            }
          ]
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "probe_evaluation"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "required": [
          "probe_evaluation"
        ],
        "not": {
          "anyOf": [
            {
              "required": [
                "outcome_feedback"
              ]
            },
            {
              "required": [
                "amendment"
              ]
            }
          ]
        }
      }
    }
  ]
}
